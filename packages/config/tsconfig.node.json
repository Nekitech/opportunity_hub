{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "outDir": "./dist",
        "isolatedModules": false,
        "downlevelIteration": true
    },
    "exclude": ["node_modules", "dist"]
}
