{
    "name": "@repo/web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3001",
        "build": "next build",
        "start": "next start -p 3001",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "test": "jest --passWithNoTests"
    },
    "dependencies": {
        "@repo/types": "workspace:*",
        "@repo/ui": "workspace:*",
        "@tanstack/react-query": "^5.0.0",
        "@types/three": "^0.184.1",
        "axios": "^1.16.1",
        "next": "^16.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "three": "^0.184.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@repo/config": "workspace:*",
        "@types/jest": "^29.5.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "autoprefixer": "^10.4.0",
        "jest": "^29.7.0",
        "jest-environment-node": "^29.7.0",
        "postcss": "^8.4.0",
        "tailwindcss": "^3.4.0",
        "ts-jest": "^29.4.0",
        "typescript": "^5.0.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": ["**/__tests__/**/*.test.ts"],
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/$1",
