{
    "extends": "@repo/config/tsconfig.react.json",
    "compilerOptions": {
        "target": "ES2017",
        "module": "esnext",
        "lib": ["dom", "dom.iterable", "esnext"],
        "noEmit": true,
        "jsx": "preserve",
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "plugins": [{ "name": "next" }],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
